@model POOI_cibertec_demo.Models.Producto

<h2>Registro de producto</h2>
<form class="col-lg-4" method="post">
    <div class="mt-3">
        <label class="form-label">Nombre:</label>
        <input class="form-control" asp-for="Nombre" />
    </div>
    <div class="mt-2">
        <label class="form-label">Precio:</label>
        <input class="form-control" asp-for="Precio"/>
    </div>
    <div class="mt-2">
        <label class="form-label">Cantidad:</label>
        <input class="form-control" asp-for="Cantidad"/>
    </div>
    <div class="mt-2">
        <label class="form-label">Categoría</label>
        <input class="form-control" asp-for="Categoria" />
    </div>
    <div class="mt-3">
        <button class="btn btn-primary" type="submit">Continuar</button>
    </div>
</form>
